{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Routine Renovate updates with a 3-day delay and vulnerability alerts",
  "extends": [
    ":automergeDisabled",
    ":disableDigestUpdates",
    ":separateMultipleMajorReleases",
    ":disableMajorUpdates"
  ],
  "minimumReleaseAge": "3 day",
  "enabledManagers": [
    "gomod",
    "github-actions"
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": [
      "security",
      "dependencies"
    ]
  },
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "packageRules": [
    {
      "description": "Automerge safe updates for stable versions",
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "matchCurrentVersion": "!/^0/",
      "automerge": true
    }
  ]
}